{
  "name": "cospacex",
  "version": "2.2.1",
  "description": "COSPACEX — Multi-tenant AI Workspace Platform | Powered by Gemini AI",
  "author": "Smartlog",
  "repository": {
    "type": "git",
    "url": "https://github.com/tranky12/workspacex.git"
  },
  "main": "electron/main.js",
  "private": true,
  "scripts": {
    "dev": "node node_modules/next/dist/bin/next dev --port 3001",
    "build": "node node_modules/next/dist/bin/next build",
    "start": "node node_modules/next/dist/bin/next start",
    "lint": "eslint",
    "seed": "npx tsx prisma/seed.ts",
    "db:push": "npx prisma db push",
    "db:backfill-org": "npx tsx prisma/backfill-organizations.ts",
    "db:studio": "npx prisma studio",
    "electron:dev": "NODE_ENV=development electron electron/main.js",
    "electron:build": "npm run build && npx electron-builder --config electron-builder.json",
    "electron:mac": "npm run build && npx electron-builder --mac --config electron-builder.json",
    "electron:win": "npm run build && npx electron-builder --win --config electron-builder.json",
    "electron:all": "npm run build && npx electron-builder --mac --win --config electron-builder.json"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@auth/prisma-adapter": "^2.11.1",
    "@google/generative-ai": "^0.24.1",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@prisma/config": "^7.6.0",
    "@slack/webhook": "^7.0.8",
    "@supabase/supabase-js": "^2.101.1",
    "dotenv": "^17.4.0",
    "electron-updater": "^6.8.3",
    "googleapis": "^171.4.0",
    "jira-client": "^8.2.2",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1",
    "next": "^16.2.2",
    "next-auth": "^5.0.0-beta.30",
    "openai": "^6.33.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.20.0",
    "pptxgenjs": "^4.0.1",
    "prisma": "^7.6.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-dropzone": "^15.0.0",
    "react-markdown": "^10.1.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
