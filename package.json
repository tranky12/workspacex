{
  "name": "presalex-workspace",
  "version": "1.0.0",
  "description": "SC&L Expert Presale Workspace — Powered by AI",
  "main": "electron/main.js",
  "private": true,
  "scripts": {
    "dev": "node node_modules/next/dist/bin/next dev --port 3001",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "seed": "npx tsx prisma/seed.ts",
    "db:push": "npx prisma db push",
    "db:studio": "npx prisma studio",
    "electron:dev": "NODE_ENV=development electron electron/main.js",
    "electron:build": "next build && electron-builder --config electron-builder.json",
    "electron:mac": "next build && electron-builder --mac --config electron-builder.json",
    "electron:win": "next build && electron-builder --win --config electron-builder.json",
    "electron:all": "next build && electron-builder --mac --win --config electron-builder.json"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@auth/prisma-adapter": "^2.11.1",
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^7.6.0",
    "@slack/webhook": "^7.0.8",
    "@supabase/supabase-js": "^2.101.1",
    "googleapis": "^171.4.0",
    "jira-client": "^8.2.2",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1",
    "next": "^16.2.2",
    "next-auth": "^5.0.0-beta.30",
    "openai": "^6.33.0",
    "pdf-parse": "^2.4.5",
    "pptxgenjs": "^4.0.1",
    "prisma": "^7.6.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-dropzone": "^15.0.0",
    "react-markdown": "^10.1.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^9.0.4"
  }
}
