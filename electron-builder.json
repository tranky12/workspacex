{
    "appId": "com.smartlog.presalex",
    "productName": "PresaleX",
    "copyright": "Copyright © 2026 Smartlog",
    "icon": "electron/assets/icon.png",
    "files": [
        "electron/**/*",
        ".next/**/*",
        "public/**/*",
        "node_modules/**/*",
        "package.json",
        "next.config.ts",
        "prisma/schema.prisma"
    ],
    "extraResources": [
        {
            "from": ".next",
            "to": ".next"
        },
        {
            "from": "public",
            "to": "public"
        }
    ],
    "mac": {
        "category": "public.app-category.business",
        "target": [
            {
                "target": "dmg",
                "arch": [
                    "arm64",
                    "x64"
                ]
            }
        ],
        "icon": "electron/assets/icon.png",
        "hardenedRuntime": false,
        "gatekeeperAssess": false
    },
    "win": {
        "target": [
            {
                "target": "nsis",
                "arch": [
                    "x64"
                ]
            }
        ],
        "icon": "electron/assets/icon.png"
    },
    "nsis": {
        "oneClick": false,
        "allowToChangeInstallationDirectory": true,
        "createDesktopShortcut": true,
        "createStartMenuShortcut": true,
        "shortcutName": "PresaleX"
    },
    "dmg": {
        "title": "Install PresaleX",
        "icon": "electron/assets/icon.png",
        "contents": [
            {
                "x": 130,
                "y": 220
            },
            {
                "x": 410,
                "y": 220,
                "type": "link",
                "path": "/Applications"
            }
        ],
        "window": {
            "width": 540,
            "height": 380
        }
    },
    "publish": {
        "provider": "github",
        "owner": "tranky12",
        "repo": "workspacex"
    }
}