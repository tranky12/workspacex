// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── AUTH ─────────────────────────────────────────────────
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String        @id @default(cuid())
  name          String?
  email         String?       @unique
  emailVerified DateTime?
  image         String?
  role          String        @default("consultant")
  accounts      Account[]
  sessions      Session[]
  deals         Deal[]
  clients       Client[]
  proposals     Proposal[]
  messages      Message[]
  settings      UserSettings?
  skillRuns     SkillRun[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── USER AI SETTINGS ─────────────────────────────────────
model UserSettings {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // AI Provider
  aiProvider    String   @default("gemini") // gemini | openai | claude | azure
  aiModel       String   @default("gemini-1.5-flash")
  // API Keys (encrypt at rest in prod)
  geminiApiKey  String?  @db.Text
  openaiApiKey  String?  @db.Text
  claudeApiKey  String?  @db.Text
  azureApiKey   String?  @db.Text
  azureEndpoint String?  @db.Text
  // Integrations
  slackWebhook  String?  @db.Text
  jiraHost      String?
  jiraEmail     String?
  jiraToken     String?  @db.Text
  jiraProject   String?
  driveFolderId String?
  updatedAt     DateTime @updatedAt
}

// ─── DEALS / PIPELINE ─────────────────────────────────────
model Deal {
  id         String     @id @default(cuid())
  title      String
  company    String
  value      Float      @default(0)
  stage      String     @default("discovery")
  industry   String?
  solution   String?
  score      Int        @default(0)
  notes      String?    @db.Text
  nextStep   String?
  ownerId    String
  owner      User       @relation(fields: [ownerId], references: [id])
  clientId   String?
  client     Client?    @relation(fields: [clientId], references: [id])
  proposals  Proposal[]
  meddicData Json?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

// ─── CLIENTS ───────────────────────────────────────────────
model Client {
  id            String   @id @default(cuid())
  name          String
  industry      String?
  size          String?
  contact       String?
  phone         String?
  email         String?
  address       String?
  painPoints    String[]
  maturityLevel Int      @default(2)
  notes         String?  @db.Text
  ownerId       String
  owner         User     @relation(fields: [ownerId], references: [id])
  deals         Deal[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ─── PROPOSALS ────────────────────────────────────────────
model Proposal {
  id        String   @id @default(cuid())
  title     String
  dealId    String?
  deal      Deal?    @relation(fields: [dealId], references: [id])
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id])
  template  String?
  slides    Json
  tone      String   @default("executive")
  status    String   @default("draft")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── KNOWLEDGE BASE ────────────────────────────────────────
model KnowledgeDoc {
  id         String   @id @default(cuid())
  name       String
  type       String
  content    String   @db.Text
  embedding  Float[]
  category   String?
  tags       String[]
  fileSize   Int?
  fileUrl    String?
  uploadedBy String?
  createdAt  DateTime @default(now())
}

// ─── SKILLS ───────────────────────────────────────────────
model Skill {
  id             String     @id @default(cuid())
  name           String
  description    String     @db.Text
  icon           String     @default("🛠️")
  persona        String     @default("consultant")
  category       String     @default("custom")
  promptTemplate String     @db.Text
  variables      Json
  isBuiltin      Boolean    @default(false)
  createdBy      String?
  usageCount     Int        @default(0)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  runs           SkillRun[]
}

model SkillRun {
  id        String   @id @default(cuid())
  skillId   String
  skill     Skill    @relation(fields: [skillId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  inputs    Json
  output    String   @db.Text
  provider  String
  model     String
  createdAt DateTime @default(now())
}

// ─── CHAT MESSAGES ────────────────────────────────────────
model Message {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  persona   String
  role      String
  content   String   @db.Text
  sessionId String
  createdAt DateTime @default(now())
}
